# Google OAuth Configuration
# Get your Google Client ID from: https://console.cloud.google.com/
# 1. Create a new Google Cloud Project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:5173 (dev) and your-vercel-domain.vercel.app (production)
# 5. Copy your Client ID below

VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# API Configuration
VITE_API_URL=http://localhost:5000/api

# Production API URL (uncomment for production)
# VITE_API_URL=https://your-backend-url.vercel.app/api

# App Name
VITE_APP_NAME=SmartSpend
VITE_APP_VERSION=1.0.0

